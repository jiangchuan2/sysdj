page { background: #F5F5F5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
.container { padding: 32rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.btn-primary { background: #4F46E5; color: #fff; border-radius: 12rpx; padding: 24rpx; text-align: center; font-size: 30rpx; font-weight: 600; border: none; }
.btn-primary::after { border: none; }
.btn-primary[disabled] { background: #A5B4FC; }
.btn-danger { background: #EF4444; color: #fff; border-radius: 12rpx; padding: 24rpx; text-align: center; font-size: 30rpx; font-weight: 600; border: none; }
.btn-danger::after { border: none; }
.section-title { font-size: 28rpx; font-weight: 600; color: #374151; margin-bottom: 16rpx; }
