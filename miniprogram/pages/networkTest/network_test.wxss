/* 网络诊断测试页面 - pages/networkTest/networkTest.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 8rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.content {
  background-color: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
}

.test-button {
  width: 100%;
  margin-bottom: 20rpx;
  background-color: #007bff;
  color: #fff;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 16rpx;
}

.test-button:disabled {
  background-color: #ccc;
}

.results {
  margin-bottom: 20rpx;
}

.result-item {
  margin-bottom: 15rpx;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-left: 4rpx solid #007bff;
  border-radius: 4rpx;
}

.result-name {
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  font-size: 16rpx;
}

.result-status {
  font-size: 14rpx;
  margin-bottom: 8rpx;
  font-weight: bold;
}

.result-detail {
  font-size: 12rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.result-time {
  font-size: 12rpx;
  color: #999;
  margin-top: 8rpx;
}

.tips {
  margin-top: 20rpx;
  padding: 15rpx;
  background-color: #fff3cd;
  border-radius: 4rpx;
  border-left: 4rpx solid #ffc107;
}

.tips-title {
  display: block;
  font-weight: bold;
  color: #856404;
  margin-bottom: 8rpx;
  font-size: 14rpx;
}

.tips-content {
  display: block;
  color: #856404;
  font-size: 12rpx;
  line-height: 1.6;
}
