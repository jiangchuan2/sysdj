<!-- test-api.wxml - API测试页面 -->

<view class="container">
  <view class="header">
    <text class="title">API连接测试</text>
    <button 
      class="retry-btn" 
      bindtap="retryTests" 
      disabled="{{testing}}"
    >
      {{testing ? '测试中...' : '重新测试'}}
    </button>
  </view>

  <view class="test-results">
    <view class="result-item" wx:for="{{testResults}}" wx:key="index">
      <view class="result-header">
        <text class="result-name">{{item.name}}</text>
        <text class="result-status {{item.status.includes('✅') ? 'success' : 'fail'}}">{{item.status}}</text>
      </view>
      <view class="result-details" wx:if="item.statusCode">
        <text class="detail-label">状态码:</text>
        <text class="detail-value">{{item.statusCode}}</text>
      </view>
      <view class="result-details" wx:if="item.error">
        <text class="detail-label">错误信息:</text>
        <text class="detail-value error">{{item.error}}</text>
      </view>
      <view class="result-json" wx:if="item.response">
        <text class="json-label">响应数据:</text>
        <text class="json-content">{{JSON.stringify(item.response, null, 2)}}</text>
      </view>
    </view>
  </view>

  <view class="tips" wx:if="testing">
    <text class="tip-text">正在测试API连接，请稍候...</text>
  </view>
</view>