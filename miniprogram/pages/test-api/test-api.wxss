/* test-api.wxss - API测试页面样式 */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: white;
  padding: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.retry-btn {
  background-color: #1aad19;
  color: white;
  font-size: 28rpx;
  padding: 10rpx 20rpx;
  border-radius: 5rpx;
}

.retry-btn[disabled] {
  background-color: #ccc;
}

.test-results {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.result-item {
  margin-bottom: 20rpx;
  padding: 20rpx;
  border: 1px solid #e8e8e8;
  border-radius: 8rpx;
  background-color: #fafafa;
}

.result-item:last-child {
  margin-bottom: 0;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.result-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.result-status {
  font-size: 28rpx;
  font-weight: bold;
}

.result-status.success {
  color: #1aad19;
}

.result-status.fail {
  color: #e64340;
}

.result-details {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.detail-label {
  color: #666;
  margin-right: 10rpx;
  font-weight: bold;
}

.detail-value {
  color: #333;
}

.detail-value.error {
  color: #e64340;
}

.result-json {
  margin-top: 10rpx;
}

.json-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.json-content {
  display: block;
  font-size: 24rpx;
  color: #333;
  background-color: #f0f0f0;
  padding: 10rpx;
  border-radius: 5rpx;
  white-space: pre-wrap;
  word-break: break-all;
}

.tips {
  margin-top: 20rpx;
  text-align: center;
  padding: 20rpx;
  background-color: white;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.tip-text {
  font-size: 28rpx;
  color: #666;
}