<view class="container">
  <view class="card">
    <view class="section-title">选择实验室</view>
    <picker range="{{labs}}" value="{{labIndex}}" bindchange="onLabChange">
      <view class="picker {{labIndex >= 0 ? 'selected' : 'placeholder'}}">
        {{labIndex >= 0 ? labs[labIndex] : '请选择实验室'}}
        <text class="arrow">▼</text>
      </view>
    </picker>
  </view>

  <view class="card">
    <view class="section-title">填写信息</view>
    <view class="field">
      <text class="label">姓名</text>
      <input class="input" placeholder="请输入姓名" value="{{name}}" bindinput="onInput" data-field="name" />
    </view>
    <view class="field">
      <text class="label">学号</text>
      <input class="input" placeholder="请输入学号" value="{{studentId}}" bindinput="onInput" data-field="studentId" />
    </view>
    <view class="field">
      <text class="label">电话</text>
      <input class="input" placeholder="请输入电话" type="number" maxlength="11" value="{{phone}}" bindinput="onInput" data-field="phone" />
    </view>
  </view>

  <button class="btn-primary" bindtap="onSubmit" disabled="{{loading}}">
    {{loading ? '提交中...' : '提交登记'}}
  </button>
</view>
