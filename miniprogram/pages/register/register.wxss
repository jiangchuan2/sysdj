.container {
    padding: 40rpx;
    background-color: #f8f8f8;
    min-height: 100vh;
    box-sizing: border-box;
  }
  
  .title {
    font-size: 48rpx;
    font-weight: bold;
    text-align: center;
    margin-bottom: 60rpx;
    color: #333;
  }
  
  .form-item {
    margin-bottom: 40rpx;
  }
  
  .label {
    display: block;
    font-size: 32rpx;
    color: #666;
    margin-bottom: 20rpx;
  }
  
  .input-field {
    width: 100%;
    height: 90rpx;
    border: 1px solid #eee;
    border-radius: 8rpx;
    padding: 0 20rpx;
    font-size: 32rpx;
    background-color: #fff;
    box-sizing: border-box;
  }
  
  .picker {
    width: 100%;
    height: 90rpx;
    border: 1px solid #eee;
    border-radius: 8rpx;
    padding: 0 20rpx;
    font-size: 32rpx;
    background-color: #fff;
    display: flex;
    align-items: center;
    color: #333;
  }
  
  .submit-button {
    width: 100%;
    height: 100rpx;
    background-color: #07c160;
    color: #fff;
    font-size: 36rpx;
    border-radius: 8rpx;
    margin-top: 40rpx;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .submit-button:active {
    background-color: #06ad56;
  }