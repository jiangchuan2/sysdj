<view class="container" wx:if="{{authorized}}">
  <!-- Stats -->
  <view class="stats">
    <view class="stat-item">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">总登记</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{todayCount}}</text>
      <text class="stat-label">今日</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{labs.length}}</text>
      <text class="stat-label">实验室</text>
    </view>
  </view>

  <!-- Lab Management -->
  <view class="card">
    <view class="card-header">
      <text class="section-title">实验室管理</text>
      <view class="add-btn" bindtap="onAddLab">+ 添加</view>
    </view>
    <view class="lab-list">
      <view class="lab-item" wx:for="{{labs}}" wx:key="*this">
        <text class="lab-name">{{item}}</text>
        <view class="lab-delete" bindtap="onDeleteLab" data-lab="{{item}}">删除</view>
      </view>
      <view class="empty" wx:if="{{labs.length === 0}}">暂无实验室</view>
    </view>
  </view>

  <!-- Records -->
  <view class="card">
    <view class="card-header">
      <text class="section-title">登记记录</text>
      <view class="refresh-btn" bindtap="onRefresh">刷新</view>
    </view>
    <view class="record-list">
      <view class="record-item" wx:for="{{records}}" wx:key="_id">
        <view class="record-top">
          <text class="record-lab">{{item.lab}}</text>
          <text class="record-time">{{item.date}} {{item.time}}</text>
        </view>
        <view class="record-bottom">
          <text class="record-name">{{item.name}}</text>
          <text class="record-id">{{item.studentId}}</text>
          <text class="record-phone">{{item.phone}}</text>
        </view>
      </view>
      <view class="empty" wx:if="{{records.length === 0}}">暂无记录</view>
    </view>
  </view>
</view>

<!-- Login -->
<view class="container" wx:if="{{!authorized}}">
  <view class="login-card">
    <view class="login-icon">🔐</view>
    <view class="login-title">管理员验证</view>
    <input class="login-input" placeholder="请输入管理员密码" password="{{true}}" value="{{password}}" bindinput="onPasswordInput" />
    <button class="btn-primary" bindtap="onLogin">验证</button>
  </view>
</view>
