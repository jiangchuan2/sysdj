<view class="container">
  <view class="header">
    <text class="title">登记记录管理</text>
    <view class="header-actions">
      <button class="refresh-btn" bindtap="onRefresh">刷新</button>
      <button class="export-btn" bindtap="onExportData">导出数据</button>
    </view>
  </view>

  <!-- 筛选区域 -->
  <view class="filter-section">
    <picker bindchange="onLabFilter" value="{{labFilterIndex}}" range="{{labFilterList}}">
      <view class="filter-item">
        <text class="filter-label">实验室：</text>
        <text class="filter-value">{{labFilterList[labFilterIndex]}}</text>
      </view>
    </picker>
    
    <picker mode="date" bindchange="onDateFilter" value="{{dateFilter}}">
      <view class="filter-item">
        <text class="filter-label">日期：</text>
        <text class="filter-value">{{dateFilter || '全部'}}</text>
      </view>
    </picker>

    <!-- 新增：学号筛选 -->
    <view class="filter-item">
      <text class="filter-label">学号：</text>
      <input 
        class="filter-input" 
        placeholder="输入学号筛选" 
        bindinput="onStudentIdFilter"
        value="{{studentIdFilter}}"
      />
    </view>

    <!-- 新增：时间段筛选 -->
    <view class="time-filter">
      <text class="filter-label">时间段：</text>
      <picker mode="time" bindchange="onStartTimeFilter" value="{{startTimeFilter}}">
        <view class="time-picker">
          <text>{{startTimeFilter || '开始时间'}}</text>
        </view>
      </picker>
      <text class="time-separator">至</text>
      <picker mode="time" bindchange="onEndTimeFilter" value="{{endTimeFilter}}">
        <view class="time-picker">
          <text>{{endTimeFilter || '结束时间'}}</text>
        </view>
      </picker>
      <button class="clear-time-btn" bindtap="onClearTimeFilter">清除</button>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-number">{{totalCount}}</text>
      <text class="stat-label">总登记数</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{todayCount}}</text>
      <text class="stat-label">今日登记</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{filteredCount}}</text>
      <text class="stat-label">筛选结果</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <scroll-view class="record-list" scroll-y="true">
    <view class="record-item" wx:for="{{records}}" wx:key="_id">
      <view class="record-header">
        <text class="lab-name">{{item.lab}}</text>
        <text class="record-time">{{item.date}} {{item.time}}</text>
      </view>
      <view class="record-info">
        <text class="student-info">{{item.name}} ({{item.studentId}})</text>
        <text class="phone-info">{{item.phone}}</text>
      </view>
      <view class="record-footer">
        <text class="scan-info">{{item.fromScan ? '扫码登记' : '手动登记'}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{records.length === 0 && !loading}}">
    <text class="empty-text">暂无符合条件的登记记录</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
