.container {
    padding: 20rpx;
    background-color: #f8f8f8;
    min-height: 100vh;
  }
  
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30rpx;
  }
  
  .title {
    font-size: 40rpx;
    font-weight: bold;
    color: #333;
  }
  
  .header-actions {
    display: flex;
    gap: 15rpx;
  }
  
  .refresh-btn {
    background-color: #07c160;
    color: #fff;
    font-size: 28rpx;
    padding: 10rpx 20rpx;
    border-radius: 6rpx;
  }
  
  .export-btn {
    background-color: #007bff;
    color: #fff;
    font-size: 28rpx;
    padding: 10rpx 20rpx;
    border-radius: 6rpx;
  }
  
  .filter-section {
    background-color: #fff;
    border-radius: 12rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  }
  
  .filter-item {
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
    padding: 20rpx;
    background-color: #f5f5f5;
    border-radius: 8rpx;
  }
  
  .filter-label {
    font-size: 28rpx;
    color: #666;
    margin-right: 20rpx;
    min-width: 100rpx;
  }
  
  .filter-value {
    font-size: 28rpx;
    color: #333;
  }
  
  /* 新增：学号输入框样式 */
  .filter-input {
    flex: 1;
    font-size: 28rpx;
    color: #333;
    background-color: #fff;
    padding: 15rpx;
    border-radius: 6rpx;
    border: 1rpx solid #ddd;
  }
  
  /* 新增：时间段筛选样式 */
  .time-filter {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    padding: 20rpx;
    background-color: #f5f5f5;
    border-radius: 8rpx;
    margin-bottom: 20rpx;
  }
  
  .time-picker {
    background-color: #fff;
    padding: 15rpx 20rpx;
    border-radius: 6rpx;
    border: 1rpx solid #ddd;
    margin: 0 10rpx;
    font-size: 26rpx;
    color: #333;
    min-width: 120rpx;
    text-align: center;
  }
  
  .time-separator {
    font-size: 24rpx;
    color: #666;
    margin: 0 5rpx;
  }
  
  .clear-time-btn {
    background-color: #ff6b6b;
    color: #fff;
    font-size: 24rpx;
    padding: 8rpx 16rpx;
    border-radius: 4rpx;
    margin-left: 10rpx;
  }
  
  .stats-section {
    display: flex;
    background-color: #fff;
    border-radius: 12rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  }
  
  .stat-item {
    flex: 1;
    text-align: center;
  }
  
  .stat-number {
    display: block;
    font-size: 48rpx;
    font-weight: bold;
    color: #07c160;
    margin-bottom: 10rpx;
  }
  
  .stat-label {
    font-size: 24rpx;
    color: #666;
  }
  
  .record-list {
    max-height: 1000rpx;
  }
  
  .record-item {
    background-color: #fff;
    border-radius: 12rpx;
    padding: 30rpx;
    margin-bottom: 15rpx;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  }
  
  .record-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15rpx;
  }
  
  .lab-name {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
  }
  
  .record-time {
    font-size: 24rpx;
    color: #999;
  }
  
  .record-info {
    margin-bottom: 15rpx;
  }
  
  .student-info {
    display: block;
    font-size: 28rpx;
    color: #333;
    margin-bottom: 8rpx;
  }
  
  .phone-info {
    font-size: 26rpx;
    color: #666;
  }
  
  .record-footer {
    text-align: right;
  }
  
  .scan-info {
    font-size: 24rpx;
    color: #07c160;
    background-color: rgba(7, 193, 96, 0.1);
    padding: 4rpx 12rpx;
    border-radius: 4rpx;
  }
  
  .empty-state, .loading-state {
    text-align: center;
    padding: 100rpx 0;
  }
  
  .empty-text, .loading-text {
    font-size: 28rpx;
    color: #999;
  }