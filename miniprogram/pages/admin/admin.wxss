.stats { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.stat-item { flex: 1; background: #fff; border-radius: 16rpx; padding: 24rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.stat-num { font-size: 40rpx; font-weight: 700; color: #4F46E5; display: block; }
.stat-label { font-size: 22rpx; color: #6B7280; display: block; margin-top: 4rpx; }

.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.add-btn, .refresh-btn { font-size: 26rpx; color: #4F46E5; font-weight: 600; }

.lab-list { max-height: 400rpx; overflow-y: auto; }
.lab-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.lab-item:last-child { border-bottom: none; }
.lab-name { font-size: 28rpx; color: #1F2937; }
.lab-delete { font-size: 24rpx; color: #EF4444; }

.record-list { max-height: 600rpx; overflow-y: auto; }
.record-item { padding: 16rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.record-item:last-child { border-bottom: none; }
.record-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.record-lab { font-size: 28rpx; font-weight: 600; color: #1F2937; }
.record-time { font-size: 22rpx; color: #9CA3AF; }
.record-bottom { display: flex; gap: 24rpx; }
.record-name, .record-id, .record-phone { font-size: 24rpx; color: #6B7280; }

.empty { text-align: center; padding: 40rpx; color: #9CA3AF; font-size: 26rpx; }

.login-card { background: #fff; border-radius: 16rpx; padding: 60rpx 32rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); margin-top: 200rpx; }
.login-icon { font-size: 80rpx; }
.login-title { font-size: 36rpx; font-weight: 700; color: #1F2937; margin: 24rpx 0; }
.login-input { background: #F9FAFB; border: 2rpx solid #E5E7EB; border-radius: 12rpx; padding: 24rpx; font-size: 28rpx; margin-bottom: 32rpx; text-align: center; }
