<view class="container">
  <view class="header">
    <view class="logo-section">
      <text class="logo">🔬</text>
      <text class="title">实验室登记系统</text>
    </view>
    <text class="subtitle">智能化实验室管理平台</text>
  </view>
  <view class="main-actions">
    <view class="scan-section">
      <button class="scan-button" bindtap="onScanCode">
        <view class="scan-icon">📱</view>
        <view class="scan-content">
          <text class="scan-title">扫码登记</text>
          <text class="scan-desc">扫描实验室二维码</text>
        </view>
      </button>
    </view>
    <view class="manual-section">
      <button class="manual-button" bindtap="onManualRegister">
        <view class="manual-icon">📝</view>
        <view class="manual-content">
          <text class="manual-title">手动登记</text>
          <text class="manual-desc">选择实验室登记</text>
        </view>
      </button>
    </view>
  </view>
  <view class="admin-section">
    <text class="admin-title">管理功能</text>
    <view class="admin-buttons-top">
      <button class="admin-btn qr-btn" bindtap="onGoToQRCode">
        <text class="admin-icon">🔗</text>
        <text class="admin-text">二维码管理</text>
      </button>
      <button class="admin-btn record-btn" bindtap="onGoToAdmin">
        <text class="admin-icon">📊</text>
        <text class="admin-text">登记管理</text>
      </button>
    </view>
    <view class="admin-buttons-bottom">
      <button class="admin-btn admin-operation-btn" bindtap="navigateToAdminLogin">
        <text class="admin-icon">⚙️</text>
        <text class="admin-text">管理员操作</text>
      </button>
      <button class="admin-btn network-test-btn" bindtap="onNetworkTest">
        <text class="admin-icon">🔧</text>
        <text class="admin-text">网络诊断</text>
      </button>
    </view>
  </view>
  <view class="info-section">
    <view class="info-header">
      <text class="info-icon">💡</text>
      <text class="info-title">使用说明</text>
    </view>
    <view class="info-content">
      <view class="info-item">
        <text class="step-number">1</text>
        <text class="step-text">进入实验室后扫描对应二维码</text>
      </view>
      <view class="info-item">
        <text class="step-number">2</text>
        <text class="step-text">填写个人信息完成登记</text>
      </view>
      <view class="info-item">
        <text class="step-number">3</text>
        <text class="step-text">管理员可查看所有登记记录</text>
      </view>
    </view>
  </view>
  <view class="icp-info">
    <navigator url="https://beian.miit.gov.cn" open-type="web-view" class="icp-text">备案/许可证编号：蜀ICP备2025166847号</navigator>
  </view>
</view>
