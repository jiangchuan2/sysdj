<view class="container">
  <!-- Hero -->
  <view class="hero">
    <view class="hero-icon">🔬</view>
    <view class="hero-title">实验室登记系统</view>
    <view class="hero-sub">扫码或手动登记实验室访问记录</view>
  </view>

  <!-- Actions -->
  <view class="actions">
    <view class="action-card" bindtap="onScanCode">
      <view class="action-icon">📷</view>
      <view class="action-text">扫码登记</view>
      <view class="action-desc">扫描实验室二维码快速登记</view>
    </view>
    <view class="action-card" bindtap="onManualRegister">
      <view class="action-icon">✏️</view>
      <view class="action-text">手动登记</view>
      <view class="action-desc">手动选择实验室进行登记</view>
    </view>
  </view>

  <!-- Admin Entry -->
  <view class="admin-entry" bindtap="onGoToAdmin">
    <text>🔐 管理后台</text>
  </view>
</view>
