.hero { text-align: center; padding: 60rpx 0 40rpx; }
.hero-icon { font-size: 100rpx; }
.hero-title { font-size: 40rpx; font-weight: 700; color: #1F2937; margin-top: 16rpx; }
.hero-sub { font-size: 26rpx; color: #6B7280; margin-top: 8rpx; }

.actions { display: flex; gap: 24rpx; margin-bottom: 32rpx; }
.action-card { flex: 1; background: #fff; border-radius: 16rpx; padding: 40rpx 24rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.action-icon { font-size: 60rpx; }
.action-text { font-size: 30rpx; font-weight: 600; color: #1F2937; margin-top: 16rpx; }
.action-desc { font-size: 22rpx; color: #9CA3AF; margin-top: 8rpx; }

.admin-entry { text-align: center; padding: 24rpx; color: #6B7280; font-size: 26rpx; }
